# ====== Studio32 · Bot de atencion y captacion de leads ======
# Copia este archivo como .env y rellena los valores.

# Clave de la API de Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# ID de la hoja de Google Sheets donde se guardan los leads.
# Es la parte de la URL: docs.google.com/spreadsheets/d/<ESTE_ID>/edit
SPREADSHEET_ID=

# Puerto del servidor (opcional, por defecto 3000)
PORT=3000
