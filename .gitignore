# ── Secretos — nunca al repo ──
.env
.env.*
!.env.example
credentials.json
*.pem
*.key

# ── Dependencias ──
node_modules/

# ── Herramientas de agente / sesiones locales ──
.hermes/
# `.claude/*` y no `.claude/`: git no puede re-incluir un archivo si su directorio
# padre está excluido. Con `/*` la excepción de abajo sí funciona.
.claude/*
# Excepción: la config compartida SÍ va al repo — es lo que sincroniza los hooks
# entre portátil y sobremesa. Las sesiones y la caché siguen ignoradas.
!.claude/settings.json

# ── Datos de runtime (conversaciones, reservas, leads) ──
studio32-agent/data/*
!studio32-agent/data/.gitkeep

# ── Tenants: llevan owner.token real y WhatsApp personal — nunca al repo ──
studio32-agent/tenants/*
!studio32-agent/tenants/.gitkeep

# ── Volcados de contexto con datos personales (email/whatsapp de Pancho) ──
studio32_FULL_RAW_CONTEXT_FOR_CLAUDE_CODE.txt
Studio32_Context_Pack_for_Claude_Code.pdf

# ── Artefactos y temporales ──
*.zip
*.log
.DS_Store
Thumbs.db
.fuse_hidden*

# ── Carpeta generada solo para arrastrar a Netlify (duplicado del sitio) ──
netlify-deploy-seguro/
studio32-agent-deploy/
