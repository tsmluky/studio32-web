# ===================================================================
# Studio32 Agent · copia este archivo como .env y rellena tus valores.
# El .env NUNCA se sube a git (está en .gitignore).
# ===================================================================

# ---------- LLM (motor del agente) ----------
# Proveedor: openai | deepseek | mock. Si lo dejas vacío se autodetecta por la key
# disponible (y si no hay ninguna, usa 'mock' = simulación sin coste).
LLM_PROVIDER=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# DeepSeek (compatible con la API de OpenAI). Pon LLM_PROVIDER=deepseek o deja que
# se autodetecte si solo tienes esta key.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Endpoint compatible OpenAI (avanzado; normalmente no hace falta tocarlo)
OPENAI_BASE_URL=

# CORS del widget web embebido (dominios separados por coma; * = todos)
CORS_ORIGINS=*

# ---------- Tenant por defecto (CLI y fallback del webhook) ----------
DEFAULT_TENANT=barberia_demo

# ---------- Google Calendar (agenda de reservas) ----------
# Service account con la API de Calendar activada. Comparte el calendario de cada
# negocio con el email de la service account (permiso: "Hacer cambios en eventos").
# Usa UNA de las dos opciones:
#   A) Local / servidor con disco: ruta al archivo JSON de la service account.
GOOGLE_CREDENTIALS_FILE=
#   B) Hosting (Railway, etc.): pega el JSON completo de la clave en una sola línea.
GOOGLE_CREDENTIALS_JSON=

# ---------- WhatsApp por Twilio (BSP; el más rápido para probar) ----------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Sandbox de pruebas: whatsapp:+14155238886 · Producción: tu número Twilio/WhatsApp
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ---------- WhatsApp por Meta Cloud API (directo, alternativa sin BSP) ----------
# Lo eliges tú (cualquier texto); se pega igual en el panel de Meta al configurar el webhook.
META_VERIFY_TOKEN=studio32-verify
# Token de la app de Meta (temporal de 24h para pruebas; permanente vía System User en producción)
META_ACCESS_TOKEN=
# ID del número (no el número), lo da Meta en WhatsApp > API Setup
META_PHONE_NUMBER_ID=
META_GRAPH_VERSION=v22.0

# ---------- SMTP (avisos por email al equipo del negocio) ----------
# Para Gmail, SMTP_PASS debe ser una App Password, no la contraseña normal.
# El DESTINO de los avisos se define por tenant en tenants/<id>/handoff.json
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Studio32 <info@studio32.es>

# ---------- Panel interno de Studio32 (opcional) ----------
# Si lo defines, el panel /panel exige este token (protégelo antes de exponerlo).
PANEL_TOKEN=

# ---------- Onboarding (opcional) ----------
# Si lo defines, el formulario de alta exige este token (protege /onboarding en público).
ONBOARDING_TOKEN=

# ---------- Servidor ----------
PORT=3000
